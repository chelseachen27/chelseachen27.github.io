---
const links = [
  { label: "About", href: "#about" },
  { label: "Experience", href: "#experience" },
  { label: "Education", href: "#education" },
  { label: "Skills", href: "#skills" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-200">
  <div class="max-w-2xl mx-auto px-6 md:px-8 flex items-center justify-between h-14">
    <a href="#" class="text-lg font-semibold text-blue-600 hover:text-blue-700 transition-colors">
      CC
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="nav-link relative text-sm text-gray-500 hover:text-blue-600 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
    >
      <span class="block w-5 h-0.5 bg-gray-700 transition-all" id="bar1"></span>
      <span class="block w-5 h-0.5 bg-gray-700 transition-all" id="bar2"></span>
      <span class="block w-5 h-0.5 bg-gray-700 transition-all" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="mobile-link text-sm text-gray-500 hover:text-blue-600 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
    });
  });

  // Scroll-tracked active section
  const sections = document.querySelectorAll("section[id]");
  const navLinks = document.querySelectorAll(".nav-link");

  function setActive(id: string | null) {
    navLinks.forEach((link) => {
      link.classList.remove("text-blue-600", "font-medium");
      link.classList.add("text-gray-500");
      if (link.getAttribute("href") === `#${id}`) {
        link.classList.add("text-blue-600", "font-medium");
        link.classList.remove("text-gray-500");
      }
    });
  }

  function updateActiveNav() {
    // If scrolled to bottom, highlight last section
    if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 2) {
      const lastSection = sections[sections.length - 1];
      setActive(lastSection?.getAttribute("id"));
      return;
    }

    const scrollY = window.scrollY + 80;

    sections.forEach((section) => {
      const el = section as HTMLElement;
      const top = el.offsetTop;
      const height = el.offsetHeight;
      const id = el.getAttribute("id");

      if (scrollY >= top && scrollY < top + height) {
        setActive(id);
      }
    });
  }

  window.addEventListener("scroll", updateActiveNav);
  updateActiveNav();
</script>

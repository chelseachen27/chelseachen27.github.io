---
import { education } from "../data";
---

<section id="education" class="mb-10 md:mb-16 scroll-mt-20">
  <h2 class="mb-4 text-xs font-bold uppercase tracking-widest text-gray-400">Education</h2>
  <div class="content-card">
    <ol class="divide-y divide-gray-100">
      {education.map((edu, i) => (
        <li class:list={[i > 0 && "pt-6", i < education.length - 1 && "pb-6"]}>
          <header class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-400">
            {edu.period}
          </header>
          <h3 class="font-medium leading-snug text-gray-900">
            {edu.degree}
            {edu.honors && (
              <span class="ml-2 inline-block rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-600 border border-blue-100">
                {edu.honors}
              </span>
            )}
          </h3>
          <p class="text-sm text-gray-500 mt-0.5">{edu.school}</p>
          <p class="mt-1 text-sm text-gray-600">GPA: {edu.gpa}</p>
          {edu.details && (
            <p class="mt-2 text-sm text-gray-400">{edu.details}</p>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>

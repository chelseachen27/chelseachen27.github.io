---
import { experience } from "../data";
---

<section id="experience" class="mb-10 md:mb-16">
  <h2 class="mb-4 text-xs font-bold uppercase tracking-widest text-gray-400">Experience</h2>
  <div class="content-card">
    <ol class="divide-y divide-gray-100">
      {experience.map((job, i) => (
        <li class:list={[i > 0 && "pt-6", i < experience.length - 1 && "pb-6"]}>
          <header class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-400">
            {job.period}
          </header>
          <h3 class="font-medium leading-snug text-gray-900">
            {job.role}
            <span class="block text-sm text-gray-500 mt-0.5">{job.company} · {job.location}</span>
          </h3>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">
            {job.bullets.map((bullet) => (
              <li class="flex gap-2">
                <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-blue-300"></span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
          <ul class="mt-3 flex flex-wrap gap-1.5" aria-label="Technologies used">
            {job.technologies.map((tech) => (
              <li class="rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-600 border border-blue-100">
                {tech}
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </div>
</section>

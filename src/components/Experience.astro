---
import { experience } from "../data";
---

<section id="experience" class="mb-10 scroll-mt-16 md:mb-16 lg:mb-24 lg:scroll-mt-24">
  <h2 class="mb-4 text-xs font-bold uppercase tracking-widest text-gray-400 lg:sr-only">Experience</h2>
  <div class="content-card">
    <ol class="group/list divide-y divide-gray-100">
      {experience.map((job, i) => (
        <li class:list={[i > 0 && "pt-6", i < experience.length - 1 && "pb-6"]}>
          <div class="experience-card group relative rounded-lg p-4 -mx-2 transition-all lg:hover:!opacity-100 lg:group-hover/list:opacity-50">
            <header class="z-10 mb-2 text-xs font-semibold uppercase tracking-wide text-gray-400">
              {job.period}
            </header>
            <div class="z-10">
              <h3 class="font-medium leading-snug text-gray-900">
                <span class="experience-title transition-colors">{job.role}</span>
                <span class="block text-sm text-gray-500 mt-0.5">{job.company} · {job.location}</span>
              </h3>
              <ul class="mt-3 space-y-2 text-sm text-gray-600">
                {job.bullets.map((bullet) => (
                  <li class="flex gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-blue-300"></span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
              <ul class="mt-3 flex flex-wrap gap-1.5" aria-label="Technologies used">
                {job.technologies.map((tech) => (
                  <li class="rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-600 border border-blue-100">
                    {tech}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

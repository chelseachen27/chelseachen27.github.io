---
import { title, locationText, socials } from "../data";
---

<header class="mb-12">
  <div class="flex items-center justify-between gap-6">
    <div class="min-w-0">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900">
        <a href="/">Chelsea Chen</a>
      </h1>
      <p class="mt-1 text-lg text-gray-400">
        Siyuan · 思远
      </p>
      <h2 class="mt-3 text-base font-medium tracking-tight text-blue-600">
        {title}
      </h2>
      <p class="mt-1.5 flex items-center gap-1.5 text-sm text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3.5 w-3.5">
          <path fill-rule="evenodd" d="m9.69 18.933.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd" />
        </svg>
        {locationText}
      </p>
      <ul class="mt-4 flex items-center gap-4" aria-label="Social media">
        {socials.map((social) => (
          <li>
            <a
              class="block text-gray-400 hover:text-blue-600 transition-colors"
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${social.name} (opens in a new tab)`}
            >
              <Fragment set:html={social.icon} />
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="h-32 w-32 flex-shrink-0 overflow-hidden rounded-full border-4 border-blue-100 bg-blue-50 shadow-lg sm:h-36 sm:w-36">
      <img
        src="/photo.jpg"
        alt="Chelsea Chen"
        class="h-full w-full object-cover"
        onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=&quot;flex h-full w-full items-center justify-center text-4xl font-bold text-blue-300&quot;>CC</div>'"
      />
    </div>
  </div>
</header>
